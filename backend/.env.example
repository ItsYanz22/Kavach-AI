# Kavach AI – Backend Environment Variables
# ============================================================================

# ─── API KEYS ──────────────────────────────────────────────────────────────
# Groq API Key for LLM-powered threat analysis
# Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: Multiple API keys for rotation/failover
# GROQ_API_KEYS=key1,key2,key3

# ─── DATABASE ──────────────────────────────────────────────────────────────
# SQLite for local development (default)
# PostgreSQL for production: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./kavach.db

# ─── JWT AUTHENTICATION ────────────────────────────────────────────────────
# JWT secret key for token signing (MUST be set in production!)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# ─── CORS CONFIGURATION ────────────────────────────────────────────────────
# Frontend origins allowed to make requests
# Format: comma-separated list of URLs
# Example: https://app.run.app,https://example.com
# For Cloud Run: https://your-service-name.run.app
# For local development, leave empty (defaults to localhost variants)
CORS_ORIGINS=

# ─── SERVER CONFIG ──────────────────────────────────────────────────────────
# Environment: local, docker-dev, production
ENVIRONMENT=local

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── CLOUD RUN ──────────────────────────────────────────────────────────────
# Cloud Run passes PORT via environment; can be overridden here
PORT=8080
HOST=0.0.0.0

# ─── WEBSOCKET ──────────────────────────────────────────────────────────────
# WebSocket cleanup interval (seconds)
WS_HEARTBEAT_INTERVAL=30
WS_SESSION_TIMEOUT=1800
