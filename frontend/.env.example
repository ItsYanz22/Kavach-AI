# Kavach AI – Frontend Environment Variables
# ============================================================================
# Usage:
# 1. For LOCAL DEVELOPMENT (Vite dev server on :5173):
#    - Leave VITE_BACKEND_URL empty or unset
#    - App will auto-detect backend at http://localhost:8000
#
# 2. For DOCKER COMPOSE (frontend service):
#    - Set VITE_BACKEND_URL=http://backend:8000
#    - This uses the Docker DNS name for backend service
#
# 3. For CLOUD RUN (production):
#    - Leave VITE_BACKEND_URL empty or unset
#    - App will use window.location.origin (same domain as frontend)
#    - Backend must serve frontend from /

# Optional: Explicit backend API URL
# This overrides the automatic detection
# Leave blank for development (will use http://localhost:8000)
# For Docker: set to http://backend:8000
# For production: leave blank (will use current domain)
VITE_BACKEND_URL=

# Optional: Enable debug logging in browser console
# VITE_DEBUG=true
