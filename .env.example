# Kavach AI - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API KEYS & AUTHENTICATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Groq API Key
# Get from: https://console.groq.com/
# Leave empty to use fallback scenarios
GROQ_API_KEY=

# Optional: Comma-separated list for automatic key rotation
# GROQ_API_KEYS=key1,key2,key3

# JWT Secret for token signing
# Generate with: openssl rand -hex 32
# CHANGE THIS IN PRODUCTION!
JWT_SECRET_KEY=dev-secret-key-change-in-production

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# SQLite (local development)
DATABASE_URL=sqlite:///./kavach.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://username:password@localhost:5432/kavach

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SERVER CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Environment: local, staging, production
ENVIRONMENT=local

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# Debug mode
DEBUG_MODE=true

# Port (Cloud Run uses 8080)
PORT=8080

# Host
HOST=0.0.0.0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT token expiration (hours)
JWT_EXPIRATION_HOURS=24

# Refresh token expiration (days)
JWT_REFRESH_EXPIRATION_DAYS=30

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WEBSOCKET & AI
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# WebSocket session timeout (seconds)
WS_SESSION_TIMEOUT=1800

# WebSocket heartbeat interval (seconds)
WS_HEARTBEAT_INTERVAL=30

# AI request timeout (seconds)
AI_REQUEST_TIMEOUT=30

# Enable fallback scenarios when LLM fails
AI_FALLBACK_ENABLED=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PRODUCTION NOTES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 1. NEVER commit .env to version control
# 2. Use Google Secret Manager for production secrets
# 3. Generate JWT_SECRET_KEY with: openssl rand -hex 32
# 4. For Cloud Run, set variables via:
#    gcloud run deploy ... --set-env-vars KEY=VALUE
# 5. For Cloud SQL, use Cloud SQL Proxy connection string
# 6. Keep all production keys secure and rotate regularly

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL: CLOUD DEPLOYMENT EXAMPLE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# For Google Cloud Run deployment:
# ENVIRONMENT=production
# LOG_LEVEL=INFO
# DEBUG_MODE=false
# DATABASE_URL=postgresql://user:pass@cloudsql-proxy:5432/kavach
# GROQ_API_KEY=<your-production-key>
# JWT_SECRET_KEY=<generated-key>
